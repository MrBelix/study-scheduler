# Скопіюй у .env і заповни реальними значеннями: cp .env.example .env
# .env у git НЕ потрапляє (див. .gitignore).

# Telegram bot token (від @BotFather)
TELEGRAM_BOT_TOKEN=

# Креди локального Postgres (для docker compose).
# Це значення compose підставляє і в postgres, і в connection string API.
POSTGRES_DB=studyscheduler
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev
